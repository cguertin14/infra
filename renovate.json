{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "extends": [
    "config:recommended"
  ],
  "groupName": "all dependencies",
  "groupSlug": "all",
  "lockFileMaintenance": {
    "enabled": false
  },
  "ignorePaths": [
    "**/.terraform.lock.hcl",
    "services/educs/topology/mongo"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "velero/velero-plugin-for-aws"
      ],
      "enabled": false
    },
    {
      "groupName": "all dependencies",
      "groupSlug": "all",
      "matchPackageNames": [
        "*"
      ]
    }
  ],
  "separateMajorMinor": true
}
